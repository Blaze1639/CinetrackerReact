cat > .gitignore << 'EOF'
# Node
node_modules/
dist/
.vite/

# Docker data
docker/mysql/data/

# Environnement
.env
.env.local

# OS
.DS_Store
Thumbs.db
.bash_history

# IDE / outils
.idea/
.vscode/
.claude.json
.claude.json.backup
*.backup
codeium_*
blocklist.json
user_settings.pb

# Logs
*.log
EOF